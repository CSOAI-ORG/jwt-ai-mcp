{
  "name": "jwt-ai-mcp",
  "description": "> **By [MEOK AI Labs](https://meok.ai)** \u2014 MEOK AI Labs \u2014 JWT token operations \u2014 decode, validate, generate, inspect.",
  "version": "1.0.0",
  "tools": [
    {
      "name": "decode_jwt",
      "description": "Decode a JWT token and show header, payload, signature.",
      "parameters": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          }
        },
        "required": [
          "token"
        ]
      }
    },
    {
      "name": "validate_jwt",
      "description": "Validate JWT signature and expiration.",
      "parameters": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "secret": {
            "type": "string"
          }
        },
        "required": [
          "token"
        ]
      }
    },
    {
      "name": "generate_jwt",
      "description": "Generate a signed JWT token.",
      "parameters": {
        "type": "object",
        "properties": {
          "payload": {
            "type": "string"
          },
          "secret": {
            "type": "string"
          },
          "algorithm": {
            "type": "string"
          }
        },
        "required": [
          "payload",
          "secret"
        ]
      }
    },
    {
      "name": "inspect_claims",
      "description": "Inspect JWT claims \u2014 issuer, audience, expiration, custom claims.",
      "parameters": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          }
        },
        "required": [
          "token"
        ]
      }
    }
  ]
}